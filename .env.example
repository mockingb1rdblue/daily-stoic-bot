# Discord (set as Worker secrets via `wrangler secret put`)
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# KV keys (store via wrangler kv)
# PROXY_API_KEY — LLM provider auth
# STOIC_DISCORD_APP_ID — Discord app ID
# STOIC_DISCORD_PUBLIC_KEY — Discord public key
# STOIC_DISCORD_BOT_TOKEN — Discord bot token
